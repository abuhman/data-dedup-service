generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Job {
  id          String   @id
  status      String
  createdAt   DateTime @default(now())

  uniqueCount Int
  duplicateCount Int

  results Result[]
}

model Result {
  id        Int    @id @default(autoincrement())
  name      String
  normalizedName String
  isDuplicate Boolean

  jobId String
  job   Job @relation(fields: [jobId], references: [id])
}